[Unit]
Description=Locus D-Bus graph daemon
Documentation=https://github.com/vafu/locus
After=graphical-session.target

[Service]
Type=simple
Environment=PATH=%h/.cargo/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.cargo/bin/locusd --schema %h/.config/locus/schema.yaml
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
